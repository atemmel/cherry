import str

# is-space
assert (str'is-space " ")

# trim-left
#assert (str'trim-left " hasse") == hasse #TODO: this crashes the test

# join
assert (str'join [hello world] ",") == "hello,world"
assert (str'join [hello] ",") == "hello"
assert (str'join [] ",") == ""
assert (str'join [hello to this world of ours] ",") == "hello,to,this,world,of,ours"
